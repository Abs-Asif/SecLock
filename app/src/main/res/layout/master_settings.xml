<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Simple Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Master Settings"
                android:textColor="?android:textColorPrimary"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nuclear Wipe Section Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="8dp"
            android:text="Nuclear Wipe"
            android:textAllCaps="true"
            android:textColor="?android:attr/colorAccent"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Nuclear Wipe Card Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- Nuclear wipe ON/OFF switch -->
            <Switch
                android:id="@+id/master_settings_nuclear_wipe_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:drawableStart="@drawable/ic_lock"
                android:drawablePadding="16dp"
                android:minHeight="64dp"
                android:paddingHorizontal="16dp"
                android:text="Nuclear wipe"
                android:textColor="?android:textColorPrimary"
                android:textSize="16sp"
                android:thumbTint="@color/switch_thumb"
                android:trackTint="@color/switch_track" />

            <View
                android:id="@+id/master_settings_nuclear_wipe_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="?android:attr/listDivider" />

            <!-- Nuclear wipe password set/change -->
            <TextView
                android:id="@+id/master_settings_nuclear_wipe_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:drawableStart="@drawable/ic_password"
                android:drawablePadding="16dp"
                android:gravity="center_vertical"
                android:minHeight="64dp"
                android:paddingHorizontal="16dp"
                android:textColor="?android:textColorPrimary"
                android:textSize="16sp"
                tools:text="nuclear wipe password set/change" />
        </LinearLayout>

        <!-- Fallback Storage Section Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="8dp"
            android:text="Fallback Storage"
            android:textAllCaps="true"
            android:textColor="?android:attr/colorAccent"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Fallback Storage Card Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- Fallback storage ON/OFF switch -->
            <Switch
                android:id="@+id/master_settings_fallback_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:drawableStart="@drawable/ic_storage"
                android:drawablePadding="16dp"
                android:minHeight="64dp"
                android:paddingHorizontal="16dp"
                android:text="Fallback storage"
                android:textColor="?android:textColorPrimary"
                android:textSize="16sp"
                android:thumbTint="@color/switch_thumb"
                android:trackTint="@color/switch_track" />

            <View
                android:id="@+id/master_settings_fallback_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="?android:attr/listDivider" />

            <!-- Fallback storage password set/change -->
            <TextView
                android:id="@+id/master_settings_fallback_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:drawableStart="@drawable/ic_password"
                android:drawablePadding="16dp"
                android:gravity="center_vertical"
                android:minHeight="64dp"
                android:paddingHorizontal="16dp"
                android:textColor="?android:textColorPrimary"
                android:textSize="16sp"
                tools:text="Fallback storage password set/change" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
