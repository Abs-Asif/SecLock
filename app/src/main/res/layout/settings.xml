<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Simple Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_label"
                android:textColor="?android:textColorPrimary"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- General Card Section Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="8dp"
            android:text="General"
            android:textAllCaps="true"
            android:textColor="?android:attr/colorAccent"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- General Card Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- Uninstall prevention switch -->
            <Switch
                android:id="@+id/settings_uninstall_prevention"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:drawableStart="@drawable/ic_lock"
                android:drawablePadding="16dp"
                android:minHeight="64dp"
                android:paddingHorizontal="16dp"
                android:text="Uninstall prevention"
                android:textColor="?android:textColorPrimary"
                android:textSize="16sp"
                android:thumbTint="@color/switch_thumb"
                android:trackTint="@color/switch_track" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="?android:attr/listDivider" />

            <!-- Show shortcut switch -->
            <Switch
                android:id="@+id/settings_show_shortcut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:drawableStart="@drawable/ic_shortcut_configuration"
                android:drawablePadding="16dp"
                android:minHeight="64dp"
                android:paddingHorizontal="16dp"
                android:text="@string/configuration_shortcut"
                android:textColor="?android:textColorPrimary"
                android:textSize="16sp"
                android:thumbTint="@color/switch_thumb"
                android:trackTint="@color/switch_track" />
        </LinearLayout>

        <!-- Credits Section Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="8dp"
            android:text="Credits"
            android:textAllCaps="true"
            android:textColor="?android:attr/colorAccent"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Credits Card Section: One line at a time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/credits_line1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?android:textColorPrimary"
                android:textSize="14sp"
                android:paddingVertical="2dp"
                tools:text="Originally created by 2bllw8." />

            <TextView
                android:id="@+id/credits_line2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?android:textColorPrimary"
                android:textSize="14sp"
                android:paddingVertical="2dp"
                tools:text="Forked and Modified by Abdullah Bari." />

            <TextView
                android:id="@+id/credits_line3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?android:textColorPrimary"
                android:textSize="14sp"
                android:paddingVertical="2dp"
                tools:text="Version 2026.07.16.359" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
